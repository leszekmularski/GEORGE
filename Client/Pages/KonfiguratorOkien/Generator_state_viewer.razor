    private async Task CopySegmentDataToClipboard()
    {
        if (wybranyStan?.Kontur == null || !wybranyStan.Kontur.Any())
            return;

        try
        {
            // Tworzenie tekstu z danymi wszystkich segmentów
            var sb = new System.Text.StringBuilder();

            sb.AppendLine("=== DANE SEGMENTÓW KONTURU ===");
            sb.AppendLine($"Liczba segmentów: {wybranyStan.Kontur.Count}");
            sb.AppendLine($"Data: {DateTime.Now:yyyy-MM-dd HH:mm:ss}");
            sb.AppendLine(new string('-', 50));

            for (int i = 0; i < wybranyStan.Kontur.Count; i++)
            {
                var segment = wybranyStan.Kontur[i];

                sb.AppendLine($"\n📌 SEGMENT #{i + 1}");
                sb.AppendLine($"   Typ: {(segment.Type == SegmentType.Arc ? "ŁUK" : "LINIA")}");
                sb.AppendLine($"   Informacja: {segment.Informacja ?? "brak"}");
                sb.AppendLine($"   Punkt początkowy: X={segment.Start.X:F4}, Y={segment.Start.Y:F4}");
                sb.AppendLine($"   Punkt końcowy: X={segment.End.X:F4}, Y={segment.End.Y:F4}");

                if (segment.Type == SegmentType.Arc)
                {
                    sb.AppendLine($"   → DANE ŁUKU:");
                    if (segment.Center.HasValue)
                    {
                        sb.AppendLine($"      Środek: X={segment.Center.Value.X:F4}, Y={segment.Center.Value.Y:F4}");
                    }
                    sb.AppendLine($"      Promień: {segment.Radius:F4}");
                    sb.AppendLine($"      Kierunek: {(segment.CounterClockwise ? "Przeciwnie do ruchu wskazówek zegara" : "Zgodnie z ruchem wskazówek zegara")}");

                    // Oblicz kąt początkowy i końcowy
                    if (segment.Center.HasValue)
                    {
                        double startAngle = Math.Atan2(segment.Start.Y - segment.Center.Value.Y,
                                                       segment.Start.X - segment.Center.Value.X) * 180 / Math.PI;
                        double endAngle = Math.Atan2(segment.End.Y - segment.Center.Value.Y,
                                                     segment.End.X - segment.Center.Value.X) * 180 / Math.PI;

                        if (startAngle < 0) startAngle += 360;
                        if (endAngle < 0) endAngle += 360;

                        sb.AppendLine($"      Kąt początkowy: {startAngle:F2}°");
                        sb.AppendLine($"      Kąt końcowy: {endAngle:F2}°");
                    }
                }
                else
                {
                    // Dla linii - oblicz długość
                    double length = Math.Sqrt(
                        Math.Pow(segment.End.X - segment.Start.X, 2) +
                        Math.Pow(segment.End.Y - segment.Start.Y, 2)
                    );
                    sb.AppendLine($"   → DŁUGOŚĆ LINII: {length:F4}");
                }

                sb.AppendLine(new string('-', 40));
            }

            // Dodaj podsumowanie
            sb.AppendLine($"\n📊 PODSUMOWANIE:");
            sb.AppendLine($"   Łuki: {wybranyStan.Kontur.Count(s => s.Type == SegmentType.Arc)}");
            sb.AppendLine($"   Linie: {wybranyStan.Kontur.Count(s => s.Type == SegmentType.Line)}");

            // Kopiuj do schowka używając JSRuntime
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", sb.ToString());

            // Pokaż komunikat (używając Twojego mechanizmu)
            pokazKomunikatKopiowania = true;
            StateHasChanged();
            await Task.Delay(2000);
            pokazKomunikatKopiowania = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Błąd podczas kopiowania: {ex.Message}");
            // Opcjonalnie pokaż błąd
        }
    }

    private double CalculateArcLength(ContourSegment segment)
    {
        if (segment.Type != SegmentType.Arc || !segment.Center.HasValue)
            return 0;

        double startAngle = Math.Atan2(segment.Start.Y - segment.Center.Value.Y,
                                       segment.Start.X - segment.Center.Value.X);
        double endAngle = Math.Atan2(segment.End.Y - segment.Center.Value.Y,
                                     segment.End.X - segment.Center.Value.X);

        double angleDiff = Math.Abs(endAngle - startAngle);
        if (angleDiff > Math.PI) angleDiff = 2 * Math.PI - angleDiff;

        return segment.Radius * angleDiff;
    }
    
