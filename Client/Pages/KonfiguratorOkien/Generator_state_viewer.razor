                                            </div>
                                            <div class="card-body">
                                                @if (wybranyStan.WybranyModel != null)
                                                {
                                                    <h6 class="@(ciemnyMotyw ? "text-light" : "text-dark")">
                                                        @wybranyStan.WybranyModel.NazwaKonfiguracji
                                                    </h6>
