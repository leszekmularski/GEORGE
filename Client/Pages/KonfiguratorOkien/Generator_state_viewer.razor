                                                            <span class="property-value">
                                                                X: @segment.Start.X.ToString("F2"), Y: @segment.Start.Y.ToString("F2")
                                                            </span>
                                                        </div>

                                                        <!-- Punkt końcowy -->
                                                        <div class="property">
                                                            <span class="property-label">Punkt końcowy:</span>
                                                            <span class="property-value">
                                                                X: @segment.End.X.ToString("F2"), Y: @segment.End.Y.ToString("F2")
                                                            </span>
                                                        </div>

