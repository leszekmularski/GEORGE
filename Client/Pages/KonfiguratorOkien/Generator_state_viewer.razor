                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else if (aktywnaZakladka == 2 && wybranyStan?.MVCKonfModelu?.KonfSystem != null)
                        {
                            <!-- WIDOK ELEMENTÓW -->
                            <div class="elements-view">
