@code {

    [Parameter]
    public ConstWlasciwosciOkna? Model { get; set; }

    [Parameter]
    public EventCallback<ConstWlasciwosciOkna> OnSave { get; set; }

    public async Task ZapiszDoRodzica()
    {
        await OnSave.InvokeAsync(Model);
    }

    private bool _calculatorVisible = false;
    private string _calculatorExpression = "";
    private int _currentEditingIndex = -1;

    private void ShowCalculator(int index)
    {
        _currentEditingIndex = index;
        _calculatorVisible = true;

        // Opcjonalnie: załaduj aktualną wartość do kalkulatora
        if (Model?.EditableProperties != null && index >= 0 && index < Model.EditableProperties.Count)
        {
            _calculatorExpression = Model.GetPropertyValue(index).ToString();
        }
    }

    private async Task PodzielLinieSymetrycznieAsync()
{
    if (Model?.EditableProperties == null || Model.EditableProperties.Count == 0)
        return;

    var linieIndeksy = new List<int>();
    
    for (int i = 0; i < Model.EditableProperties.Count; i++)
    {

        if (Model.GetLinia(i))
        {
            linieIndeksy.Add(i);
        }
    }
    
    int iloscLinii = linieIndeksy.Count;
    
    if (iloscLinii > 0 && Model.Szerokosc > 0)
    {
        double odstep = Model.Szerokosc / (iloscLinii + 1);
        
        // Aktualizuj wszystkie linie
        for (int i = 0; i < linieIndeksy.Count; i++)
        {
            int index = linieIndeksy[i];
            double nowaPozycja = Math.Round(odstep * (i + 1), 0);
            
            Model.UpdateEditableProperty(index, nowaPozycja);
        }
        
        // Zapisz zmiany
        await ZapiszDoRodzica();
        
      //  Console.WriteLine($"Podzielono {iloscLinii} linii symetrycznie. Odstęp: {odstep:F2}mm");
    }
    else
    {
        // Możesz dodać powiadomienie dla użytkownika
        Console.WriteLine("Nie można podzielić linii - brak linii lub szerokość = 0");
    }
}

    private void AppendToCalculator(string value)
    {
        _calculatorExpression += value;
    }

    private void ClearCalculator()
    {
        _calculatorExpression = "";
    }

    private void BackspaceCalculator()
    {
        if (_calculatorExpression.Length > 0)
        {
            _calculatorExpression = _calculatorExpression.Substring(0, _calculatorExpression.Length - 1);
        }
    }

    private void UseCurrentValue()
    {
        if (Model?.EditableProperties != null && _currentEditingIndex >= 0 && 
            _currentEditingIndex < Model.EditableProperties.Count)
        {
            _calculatorExpression = Model.GetPropertyValue(_currentEditingIndex).ToString();
        }
    }

    private void CalculateResult()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(_calculatorExpression))
                return;
            
            // Używamy DataTable do obliczenia wyrażenia
            var dataTable = new System.Data.DataTable();
            var result = dataTable.Compute(_calculatorExpression.Replace("×", "*").Replace("÷", "/").Replace("−", "-"), null);
            _calculatorExpression = Convert.ToDouble(result).ToString("0.#####");
        }
        catch (Exception)
        {
            _calculatorExpression = "Błąd";
            // Opcjonalnie: automatycznie wyczyść po chwili
            Task.Delay(1000).ContinueWith(_ => 
            {
                _calculatorExpression = "";
                InvokeAsync(StateHasChanged);
            });
        }
    }
    
    private async Task HandleCalculatorOk()
    {
        if (_currentEditingIndex >= 0 && !string.IsNullOrWhiteSpace(_calculatorExpression))
        {
            try
            {
                // Oblicz wynik końcowy przed zapisaniem
                var dataTable = new System.Data.DataTable();
                var result = dataTable.Compute(_calculatorExpression.Replace("×", "*").Replace("÷", "/").Replace("−", "-"), null);
                double finalValue = Convert.ToDouble(result);
                
                // Aktualizuj właściwość
                Model.UpdateEditableProperty(_currentEditingIndex, finalValue);
                await ZapiszDoRodzica();
            }
            catch
            {
                // Jeśli nie można obliczyć, spróbuj zapisać jako string
                Model.UpdateEditableProperty(_currentEditingIndex, 0);
                await ZapiszDoRodzica();
            }
        }
        
        _calculatorVisible = false;
        _currentEditingIndex = -1;
    }
    
    private Task HandleCalculatorCancel()
    {
        _calculatorVisible = false;
        _currentEditingIndex = -1;
        return Task.CompletedTask;
    }
}