@using GEORGE.Client.Pages.Models

@if (Model == null)
{
    <p class="text-muted">Brak danych do edycji okna.</p>
}
else
{
    <EditForm Model="Model">
        <DataAnnotationsValidator />

        <AntDesign.Row Gutter="16">

            <AntDesign.Col Xs="24" Sm="12">
                <h5>Wymiary</h5>

@*                 <div class="mb-2">
                    <label>Szerokość [mm]</label>
                    <AntDesign.InputNumber @bind-Value="Model.Szerokosc" 
                      Style="width: 100%;"
                      @bind-Value:after="async () => await ZapiszDoRodzica()" />
                </div>

                <div class="mb-2">
                    <label>Wysokość [mm]</label>
                    <AntDesign.InputNumber @bind-Value="Model.Wysokosc" 
                      Style="width: 100%;"
                      @bind-Value:after="async () => await ZapiszDoRodzica()" />
                </div> *@

                @if (Model.EditableProperties != null && Model.EditableProperties.Count > 0)
{
    for (int i = 0; i < Model.EditableProperties.Count; i++)
    {
        var index = i;
        var prop = Model.EditableProperties[index];

        <div class="mb-2">
            @if (!prop.systemowa)
            {
                @if (!prop.IsReadOnly)
                {
                    <label>@prop.Label</label>
                    <div style="display: flex; align-items: center; gap: 5px;">
                        <AntDesign.InputNumber Value="@Model.GetPropertyValue(index)"
                                              ValueChanged="@(async (double value) => {
                                                  Model.UpdateEditableProperty(index, value);
                                                  await ZapiszDoRodzica();
                                              })"
                                              Style="flex: 1;" />
                        
                                    <AntDesign.Button Type="@ButtonType.Default"
                                                     Icon="calculator"
                                                     OnClick="@(() => ShowCalculator(index))"
                                                     Size="small"
                                                     Style="height: 32px;">
                                    </AntDesign.Button>
                                    @if(Model.GetLinia(index))
                                    {
                                        <AntDesign.Button Type="@ButtonType.Default"
                                                         Icon="pic-center"
                                                         OnClick="@(() => PodzielLinieSymetrycznieAsync())"
                                                         Size="small"
                                                         Style="height: 32px;">
                                        </AntDesign.Button>
                                    }
                                    </div>
                }
                else if(prop.IsReadOnly)
                {
                    <label>@prop.Label</label>
                    <AntDesign.InputNumber Value="@Model.GetPropertyValue(index)"
                                          Style="width: 100%;"
                                          Disabled="true" />
                }
            }
        </div>
    }
}

@* Modal kalkulatora *@
<AntDesign.Modal Title="Kalkulator"
                 Visible="@_calculatorVisible"
                 OnOk="@HandleCalculatorOk"
                 OnCancel="@HandleCalculatorCancel"
                 Width="350">
    
    <div style="padding: 10px;">
        @* Wyświetlacz *@
        <div style="background-color: #f0f0f0; padding: 10px; margin-bottom: 10px; 
                    text-align: right; font-size: 20px; font-weight: bold; 
                    border: 1px solid #d9d9d9; border-radius: 4px; min-height: 40px;">
            @(_calculatorExpression.Length > 0 ? _calculatorExpression : "0")
        </div>
        
        @* Przyciski kalkulatora *@
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px;">
            @* Rząd 1 *@
            <AntDesign.Button OnClick="@(() => AppendToCalculator("7"))" Block>7</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator("8"))" Block>8</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator("9"))" Block>9</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator("/"))" 
                             Type="@ButtonType.Primary" Block>÷</AntDesign.Button>
            
            @* Rząd 2 *@
            <AntDesign.Button OnClick="@(() => AppendToCalculator("4"))" Block>4</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator("5"))" Block>5</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator("6"))" Block>6</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator("*"))" 
                             Type="@ButtonType.Primary" Block>×</AntDesign.Button>
            
            @* Rząd 3 *@
            <AntDesign.Button OnClick="@(() => AppendToCalculator("1"))" Block>1</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator("2"))" Block>2</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator("3"))" Block>3</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator("-"))" 
                             Type="@ButtonType.Primary" Block>−</AntDesign.Button>
            
            @* Rząd 4 *@
            <AntDesign.Button OnClick="@(() => AppendToCalculator("0"))" Block>0</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator("."))" Block>.</AntDesign.Button>
            <AntDesign.Button OnClick="@CalculateResult" 
                             Type="@ButtonType.Primary" 
                             Style="background-color: #52c41a; border-color: #52c41a;" 
                             Block>=</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator("+"))" 
                             Type="@ButtonType.Primary" Block>+</AntDesign.Button>
            
            @* Dodatkowe przyciski *@
            <AntDesign.Button OnClick="@ClearCalculator" 
                             Type="@ButtonType.Primary" 
                             Block>C</AntDesign.Button>
            <AntDesign.Button OnClick="@BackspaceCalculator" Block>⌫</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator("("))" Block>(</AntDesign.Button>
            <AntDesign.Button OnClick="@(() => AppendToCalculator(")"))" Block>)</AntDesign.Button>
        </div>
        
        @* Przyciski akcji *@
        <div style="display: flex; gap: 5px; margin-top: 10px;">
            <AntDesign.Button OnClick="@UseCurrentValue" 
                             Type="@ButtonType.Default" 
                             Block>
                Użyj bieżącej wartości
            </AntDesign.Button>
            <AntDesign.Button OnClick="@ClearCalculator" 
                             Type="@ButtonType.Default" 
                             Block>
                Wyczyść
            </AntDesign.Button>
        </div>
    </div>
</AntDesign.Modal>

